# PhilSA POC — single .env template. Copy to `.env` (gitignored) and fill in.
#
# One file holds every backend secret/config: all pipeline scripts and
# compose.viz.yml auto-load the repo-root `.env`. Override the path with ENV_FILE=…
# The webmap is separate — it reads its own `webmap/.env` (Vite VITE_* vars).

# --- Cloudflare R2 (S3-compatible object storage) ---
R2_BUCKET=your-bucket
R2_ACCOUNT_ID=your-cloudflare-account-id
# Public base URL (r2.dev subdomain or custom domain) for printed/asset hrefs.
R2_PUBLIC_BASE=https://pub-xxxxxxxx.r2.dev
# R2 API token (Object Read & Write), used as S3 SigV4 creds.
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
# NOTE: do NOT set R2_PREFIX here — each script hardcodes its own <tier>/<dataset> prefix.

# --- CopPhil / EODATA (Keycloak password grant) ---
COPPHIL_USERNAME=your-copphil-username
COPPHIL_PASSWORD=your-copphil-password
# COPPHIL_CLIENT_ID=copphil-public   # optional, this is the default
