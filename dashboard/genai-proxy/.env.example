# Copy to .env and fill in. Never commit the real key.
#   cp .env.example .env  &&  edit .env
#   set -a && source .env && set +a && node server.js

# Required: your OpenRouter API key (https://openrouter.ai/keys).
OPENROUTER_API_KEY=

# Optional overrides:
# GENAI_PROXY_PORT=8084
# GENAI_ALLOW_ORIGIN=http://localhost:3001
# GENAI_REFERER=https://philsa-poc.local/dashboard
